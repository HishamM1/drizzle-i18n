{
  "name": "drizzle-i18n",
  "version": "0.1.1",
  "description": "Type-safe database localization layer for Drizzle ORM",
  "homepage": "https://github.com/HishamM1/drizzle-i18n#readme",
  "bugs": {
    "url": "https://github.com/HishamM1/drizzle-i18n/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HishamM1/drizzle-i18n.git"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "drizzle",
    "drizzle-orm",
    "i18n",
    "localization",
    "translations",
    "typescript",
    "postgresql",
    "mysql",
    "sqlite"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./pg": {
      "import": {
        "types": "./dist/pg.d.ts",
        "default": "./dist/pg.js"
      },
      "require": {
        "types": "./dist/pg.d.cts",
        "default": "./dist/pg.cjs"
      }
    },
    "./mysql": {
      "import": {
        "types": "./dist/mysql.d.ts",
        "default": "./dist/mysql.js"
      },
      "require": {
        "types": "./dist/mysql.d.cts",
        "default": "./dist/mysql.cjs"
      }
    },
    "./sqlite": {
      "import": {
        "types": "./dist/sqlite.d.ts",
        "default": "./dist/sqlite.js"
      },
      "require": {
        "types": "./dist/sqlite.d.cts",
        "default": "./dist/sqlite.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "docs:dev": "npm --prefix docs run dev",
    "docs:build": "npm --prefix docs run build",
    "docs:start": "npm --prefix docs run start",
    "docs:typecheck": "npm --prefix docs run types:check",
    "pack:check": "npm pack --dry-run",
    "pack:smoke": "node ./scripts/pack-smoke.mjs",
    "release:check": "npm run check && npm run build && npm run pack:check && npm run pack:smoke",
    "prepublishOnly": "npm run check && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests",
    "check": "biome check src tests && tsc --noEmit && vitest run"
  },
  "peerDependencies": {
    "drizzle-orm": ">=0.35.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@changesets/cli": "^2.30.0",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.1",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT"
}
